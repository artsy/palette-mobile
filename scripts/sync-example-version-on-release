#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

VERSION="$npm_package_version"

jq --arg v "$VERSION" '.version = $v' Example/package.json > Example/package.json.tmp && mv Example/package.json.tmp Example/package.json
jq --arg v "$VERSION" '.expo.version = $v' Example/app.json > Example/app.json.tmp && mv Example/app.json.tmp Example/app.json
