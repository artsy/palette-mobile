{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "beta": {
      "distribution": "store",
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx4096m -XX:MaxMetaspaceSize=1536m -Dkotlin.daemon.jvm.options=-Xmx2048m -Dfile.encoding=UTF-8"
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "autoIncrement": true,
      "channel": "beta"
    }
  },
  "submit": {
    "beta": {
      "ios": {
        "ascAppId": "6443736418"
      },
      "android": {
        "track": "alpha",
        "serviceAccountKeyPath": "./android-service-account.json",
        "releaseStatus": "completed"
      }
    }
  }
}
