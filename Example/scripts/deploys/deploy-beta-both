#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/../.."

CURRENT_BRANCH=$(git branch --show-current)

git push origin "$CURRENT_BRANCH:beta-ios" -f --no-verify

git push origin "$CURRENT_BRANCH:beta-android" -f --no-verify

echo "✅ Beta branches updated successfully"
echo "Check status at: https://github.com/artsy/palette-mobile/actions"
