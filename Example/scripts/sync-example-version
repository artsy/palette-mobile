#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/../.."

echo "Fetching main branch..."
git fetch origin main

VERSION=$(git show origin/main:package.json | jq -r '.version')
echo "Syncing versions to $VERSION (from origin/main)..."

jq --arg v "$VERSION" '.version = $v' package.json > package.json.tmp && mv package.json.tmp package.json
jq --arg v "$VERSION" '.version = $v' Example/package.json > Example/package.json.tmp && mv Example/package.json.tmp Example/package.json
jq --arg v "$VERSION" '.expo.version = $v' Example/app.json > Example/app.json.tmp && mv Example/app.json.tmp Example/app.json

git add package.json Example/package.json Example/app.json
if ! git diff --cached --quiet; then
  git commit -m "chore: sync Example versions"
fi

echo "✅ Done"
